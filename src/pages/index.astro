---
import {
	getEmDashCollection,
	getSiteSettings,
	getTermsForEntries,
} from "emdash";
import Base from "../layouts/Base.astro";
import {
	asOptionalText,
	asText,
	profileProjects,
} from "../data/profileProjects";

type PortfolioProject = {
	title: string;
	summary: string;
	url?: string;
	client?: string;
	year?: string;
	tags: string[];
};

const [{ entries: projects, cacheHint }, settings] = await Promise.all([
	getEmDashCollection("projects", {
		orderBy: { published_at: "desc" },
		limit: 24,
	}),
	getSiteSettings(),
]);

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const projectTagsByEntry =
	projects.length > 0
		? await getTermsForEntries(
				"projects",
				projects.map((project) => asText(project.data.id)).filter(Boolean),
				"tag",
			)
		: new Map();

const cmsProjects = projects.map((project) => ({
	title: asText(project.data.title, "Untitled"),
	summary: asText(project.data.summary),
	url: asText(project.data.url) || `/work/${project.id}`,
	client: asOptionalText(project.data.client),
	year: asOptionalText(project.data.year),
	tags: (projectTagsByEntry.get(asText(project.data.id)) ?? []).map(
		(tag: { label: string }) => tag.label,
	),
}));
const portfolioProjects: PortfolioProject[] =
	cmsProjects.length > 0 ? cmsProjects : profileProjects;
const featuredProjects = portfolioProjects.slice(0, 3);
const currentYear = new Date().getFullYear();
const projectStats = [
	{ icon: "⚡", value: "20+", label: "Years programming" },
	{ icon: "</>", value: "20+", label: "Large commerce builds" },
	{ icon: "◎", value: "UK", label: "Global store experience" },
	{ icon: "♡", value: "∞", label: "Care for interfaces" },
];
const techStack = [
	{
		name: "Angular",
		iconUrl: "https://cdn.simpleicons.org/angular/DD0031",
	},
	{
		name: "TypeScript",
		iconUrl: "https://cdn.simpleicons.org/typescript/3178C6",
	},
	{
		name: "React",
		iconUrl: "https://cdn.simpleicons.org/react/61DAFB",
	},
	{
		name: "SCSS",
		iconUrl: "https://cdn.simpleicons.org/sass/CC6699",
	},
	{
		name: "NodeJS",
		iconUrl: "https://cdn.simpleicons.org/nodedotjs/5FA04E",
	},
	{
		name: "MongoDB",
		iconUrl: "https://cdn.simpleicons.org/mongodb/47A248",
	},
	{
		name: "Magento",
		textIcon: "M2",
	},
	{
		name: "Headless CMS",
		textIcon: "CMS",
	},
	{
		name: "WordPress",
		iconUrl: "https://cdn.simpleicons.org/wordpress/21759B",
	},
	{
		name: "OpenCart",
		textIcon: "OC",
	},
	{
		name: "PHP",
		iconUrl: "https://cdn.simpleicons.org/php/777BB4",
	},
	{
		name: "Cloudflare",
		iconUrl: "https://cdn.simpleicons.org/cloudflare/F38020",
	},
];
---

<Base
	chrome={false}
	title="Senior Front End Developer"
	description={settings?.tagline}
>
	<main class="portfolio-page" data-pointer-zone>
		<header class="site-header" aria-label="Primary navigation">
			<a class="brand" href="#top" aria-label="Rafal Wolak home">
				Rafal Wolak <span aria-hidden="true">.</span>
			</a>

			<nav class="top-links" aria-label="External links">
				<a
					href="https://www.linkedin.com/in/rafalwolak"
					target="_blank"
					rel="noopener noreferrer"
				>
					LinkedIn
					<svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.35 8h4.3v15H.35V8Zm7.42 0h4.12v2.05h.06c.57-1.08 1.98-2.22 4.08-2.22 4.36 0 5.17 2.87 5.17 6.6V23h-4.3v-7.6c0-1.81-.03-4.14-2.52-4.14-2.52 0-2.91 1.97-2.91 4.01V23h-4.3V8h.6Z"></path>
					</svg>
				</a>
				<a href="https://github.com/rafalwolak" target="_blank" rel="noopener noreferrer">
					GitHub
					<svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.4 7.86 10.93.58.11.79-.25.79-.56v-2.18c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.03 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18A10.95 10.95 0 0 1 12 6.01c.98 0 1.96.13 2.88.39 2.19-1.49 3.15-1.18 3.15-1.18.63 1.58.24 2.75.12 3.04.74.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.07.78 2.15v3.2c0 .31.21.67.8.56A11.52 11.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"></path>
					</svg>
				</a>
				<span class="top-divider" aria-hidden="true"></span>
				<a class="build-link" href="#contact">
					Let's build <span aria-hidden="true">↗</span>
				</a>
			</nav>
		</header>

		<section class="hero" id="top" aria-labelledby="hero-title">
			<nav class="side-rail" aria-label="Page sections">
				<a class="is-active" href="#top"><span>01</span>Home</a>
				<a href="#about"><span>02</span>About</a>
				<a href="#work"><span>03</span>Work</a>
				<a href="#stack"><span>04</span>Stack</a>
				<a href="#contact"><span>05</span>Contact</a>
			</nav>

			<div class="hero-copy">
				<p class="role-line">
					<span aria-hidden="true"></span>Senior Front End Developer
				</p>
				<h1 id="hero-title">
					Commerce frontends that <em>move</em> products.
				</h1>
				<p class="hero-intro">
					I build Angular and TypeScript front ends for high-traffic commerce,
					headless CMS workflows, Magento integrations and interface systems
					that stay fast under real usage.
				</p>
				<div class="action-row">
					<a class="primary-action" href="#work">
						View projects <span aria-hidden="true">↗</span>
					</a>
					<a class="text-action" href="#contact">Contact me</a>
				</div>
			</div>

			<div class="portrait-column" aria-label="Animated portrait area">
				<div class="portrait-stage">
					<div class="dot-field" aria-hidden="true"></div>
					<img
						class="portrait-photo"
						src="/assets/portrait-cutout.png"
						alt="Stylized portrait of Rafal Wolak."
					/>
					<svg class="portrait-eye-layer" viewBox="0 0 1122 1402" aria-hidden="true">
						<defs>
							<clipPath id="leftEyeClip">
								<ellipse cx="382" cy="594" rx="32" ry="16"></ellipse>
							</clipPath>
							<clipPath id="rightEyeClip">
								<ellipse cx="691" cy="559" rx="31" ry="15"></ellipse>
							</clipPath>
						</defs>

						<g
							class="natural-eye"
							data-eye
							data-range-x="7"
							data-range-y="3"
							clip-path="url(#leftEyeClip)"
						>
							<g data-pupil>
								<image href="/assets/portrait-cutout.png" width="1122" height="1402"></image>
							</g>
						</g>
						<g
							class="natural-eye"
							data-eye
							data-range-x="6.5"
							data-range-y="2.8"
							clip-path="url(#rightEyeClip)"
						>
							<g data-pupil>
								<image href="/assets/portrait-cutout.png" width="1122" height="1402"></image>
							</g>
						</g>

						<ellipse class="lens-depth" cx="404" cy="604" rx="94" ry="39"></ellipse>
						<ellipse class="lens-depth" cx="678" cy="569" rx="91" ry="37"></ellipse>
					</svg>
				</div>
			</div>

			<aside class="hero-projects" aria-labelledby="selected-work-title">
				<h2 id="selected-work-title">Selected projects</h2>
				{
					featuredProjects.map((project, index) => (
						<article class="project-link">
							<span>{String(index + 1).padStart(2, "0")}</span>
							<a
								href={project.url || "/work"}
								target={project.url ? "_blank" : undefined}
								rel={project.url ? "noopener noreferrer" : undefined}
							>
								{project.title}
							</a>
							<p>{project.summary}</p>
						</article>
					))
				}
				<a class="all-projects" href="#work">
					View recent work <span aria-hidden="true">↗</span>
				</a>
			</aside>
		</section>

		<section class="about-section" id="about" aria-labelledby="about-title">
			<p class="vertical-label">About me <span aria-hidden="true">↗</span></p>
			<h2 id="about-title">I turn complex commerce into clear digital experiences.</h2>
			<div class="about-copy">
				<p>
					I started programming in 2004 and moved from Flash, PHP and WordPress
					into modern SPA front ends. Since 2016, I have worked on large
					e-commerce sites for UK and worldwide brands, creating Angular-based
					headless CMS interfaces connected to Magento backends.
				</p>
				<span class="signature">Rafal Wolak</span>
			</div>
			<div class="stats" aria-label="Experience highlights">
				{
					projectStats.map((stat) => (
						<div>
							<span>{stat.icon}</span>
							<strong>{stat.value}</strong>
							<small>{stat.label}</small>
						</div>
					))
				}
			</div>
		</section>

		<section class="work-section" id="work" aria-labelledby="all-work-title">
			<div class="section-kicker">Recent commerce work</div>
			<div class="work-heading">
				<h2 id="all-work-title">Recent projects</h2>
				<p>
					A selected snapshot of recent commerce frontend and platform work
					across Angular, TypeScript, Magento and content workflow delivery.
				</p>
			</div>
			<div class="work-list">
				{
					portfolioProjects.map((project, index) => (
						<article class="work-item">
							<span class="work-index">{String(index + 1).padStart(2, "0")}</span>
							<div class="work-main">
								<a
									href={project.url || "/work"}
									target={project.url ? "_blank" : undefined}
									rel={project.url ? "noopener noreferrer" : undefined}
								>
									{project.title}
								</a>
								<p>{project.summary}</p>
								{project.tags.length > 0 && (
									<ul aria-label={`${project.title} technologies`}>
										{project.tags.map((tag) => <li>{tag}</li>)}
									</ul>
								)}
							</div>
							<div class="work-meta">
								{project.client && <span>{project.client}</span>}
								{project.year && <small>{project.year}</small>}
							</div>
						</article>
					))
				}
			</div>
		</section>

		<section class="stack-section" id="stack" aria-labelledby="stack-title">
			<h2 id="stack-title">Stack and focus</h2>
			<ul>
				{
					techStack.map((tech) => (
						<li>
							<span class="stack-icon" aria-hidden="true">
								{tech.iconUrl ? (
									<img src={tech.iconUrl} alt="" loading="lazy" />
								) : (
									<em>{tech.textIcon}</em>
								)}
							</span>
							<strong>{tech.name}</strong>
						</li>
					))
				}
			</ul>
		</section>

		<section class="contact-section" id="contact" aria-labelledby="contact-title">
			<div>
				<div class="section-kicker">Contact</div>
				<h2 id="contact-title">Tell me what you want to build.</h2>
				<p>
					Send the project context, commerce challenge or platform problem.
					The message is saved securely in the site database so I can follow up.
				</p>
				<a class="contact-email" href="mailto:kontakt@rafalwolak.pl">
					kontakt@rafalwolak.pl
				</a>
			</div>

			<form class="contact-form" data-contact-form>
				<input type="hidden" name="source" value="homepage-contact" />
				<div class="honeypot" aria-hidden="true">
					<label for="website">Website</label>
					<input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
				</div>

				<div class="form-grid">
					<label>
						<span>Name</span>
						<input name="name" type="text" autocomplete="name" required />
					</label>
					<label>
						<span>Email</span>
						<input name="email" type="email" autocomplete="email" required />
					</label>
				</div>

				<label>
					<span>Company / project</span>
					<input name="company" type="text" autocomplete="organization" />
				</label>

				<label>
					<span>Message</span>
					<textarea name="message" rows="6" required></textarea>
				</label>

				<div class="form-actions">
					<button type="submit">Send message <span aria-hidden="true">↗</span></button>
					<p data-contact-status role="status" aria-live="polite"></p>
				</div>
			</form>
		</section>

		<footer class="site-footer">
			<span>Code that keeps commerce moving. © {currentYear} Rafal Wolak.</span>
		</footer>
	</main>

	<script is:inline>
		const root = document.documentElement;
		const pointerZone = document.querySelector("[data-pointer-zone]");
		const portraitStage = document.querySelector(".portrait-stage");
		const eyes = [...document.querySelectorAll("[data-eye]")].map((eye) => ({
			pupil: eye.querySelector("[data-pupil]"),
			rangeX: Number(eye.dataset.rangeX || 7),
			rangeY: Number(eye.dataset.rangeY || 3),
		}));

		const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

		function updateGaze(clientX, clientY) {
			if (!portraitStage) return;

			const rect = portraitStage.getBoundingClientRect();
			const centerX = rect.left + rect.width / 2;
			const centerY = rect.top + rect.height / 2;
			const normalizedX = clamp((clientX - centerX) / (rect.width / 2), -1, 1);
			const normalizedY = clamp((clientY - centerY) / (rect.height / 2), -1, 1);

			root.style.setProperty("--look-x", normalizedX.toFixed(3));
			root.style.setProperty("--look-y", normalizedY.toFixed(3));

			eyes.forEach(({ pupil, rangeX, rangeY }) => {
				if (!pupil) return;
				const x = normalizedX * rangeX;
				const y = normalizedY * rangeY;
				pupil.setAttribute("transform", `translate(${x.toFixed(2)} ${y.toFixed(2)})`);
			});
		}

		function resetGaze() {
			root.style.setProperty("--look-x", "0");
			root.style.setProperty("--look-y", "0");
			eyes.forEach(({ pupil }) => pupil?.setAttribute("transform", "translate(0 0)"));
		}

		pointerZone?.addEventListener("pointermove", (event) => {
			window.requestAnimationFrame(() => updateGaze(event.clientX, event.clientY));
		});
		pointerZone?.addEventListener("pointerleave", resetGaze);
		window.addEventListener("blur", resetGaze);

		const contactForm = document.querySelector("[data-contact-form]");
		const contactStatus = document.querySelector("[data-contact-status]");

		contactForm?.addEventListener("submit", async (event) => {
			event.preventDefault();
			if (!(contactForm instanceof HTMLFormElement)) return;

			const submitButton = contactForm.querySelector("button[type='submit']");
			const formData = new FormData(contactForm);

			if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;
			if (contactStatus) contactStatus.textContent = "Sending...";

			try {
				const response = await fetch("/api/contact", {
					method: "POST",
					body: formData,
				});
				const result = await response.json();

				if (!response.ok || !result.ok) {
					throw new Error(result.message || "Message could not be sent.");
				}

				contactForm.reset();
				if (contactStatus) contactStatus.textContent = "Message saved. I will get back to you soon.";
			} catch (error) {
				if (contactStatus) {
					contactStatus.textContent =
						error instanceof Error ? error.message : "Message could not be sent.";
				}
			} finally {
				if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
			}
		});
	</script>
</Base>

<style is:global>
	.portfolio-page {
		min-height: 100svh;
		overflow: hidden;
		background:
			radial-gradient(circle at 78% 34%, rgba(0, 216, 245, 0.13), transparent 25%),
			linear-gradient(90deg, rgba(245, 245, 241, 0.025) 1px, transparent 1px),
			linear-gradient(rgba(245, 245, 241, 0.025) 1px, transparent 1px),
			var(--ink);
		background-size: 100% 100%, 74px 74px, 74px 74px, 100% 100%;
	}

	.site-header {
		position: absolute;
		top: 0;
		left: 50%;
		z-index: 20;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 28px;
		width: min(1532px, calc(100% - 54px));
		min-height: 74px;
		transform: translateX(-50%);
	}

	.brand,
	.top-links,
	.top-links a {
		display: flex;
		align-items: center;
	}

	.brand {
		gap: 8px;
		font-family: var(--font-mono);
		font-size: 1rem;
		font-weight: 780;
		letter-spacing: 0.1em;
		line-height: 1;
		text-transform: uppercase;
	}

	.brand span {
		color: var(--cyan);
	}

	.top-links {
		gap: clamp(18px, 2.5vw, 34px);
		color: var(--paper);
		font-size: 0.95rem;
		font-weight: 790;
	}

	.top-links a {
		gap: 7px;
		transition: color 160ms ease;
	}

	.top-links a:hover,
	.top-links a:focus-visible {
		color: var(--cyan);
		outline: 0;
	}

	.social-icon {
		width: 18px;
		height: 18px;
		fill: currentColor;
		flex: 0 0 auto;
	}

	.top-divider {
		width: 1px;
		height: 30px;
		background: var(--cyan-deep);
	}

	.build-link {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.build-link span {
		color: var(--cyan);
		font-size: 1.08rem;
	}

	.hero {
		display: grid;
		grid-template-columns: 128px minmax(360px, 0.92fr) minmax(460px, 1fr) minmax(210px, 0.45fr);
		align-items: center;
		gap: clamp(28px, 2.8vw, 54px);
		width: min(1532px, calc(100% - 54px));
		min-height: 93svh;
		margin: 0 auto;
		padding: 92px 0 0;
	}

	.side-rail {
		align-self: stretch;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: clamp(26px, 4vh, 44px);
		color: rgba(245, 245, 241, 0.58);
		font-family: var(--font-mono);
		text-transform: uppercase;
		transform: translateY(clamp(-90px, -7svh, -52px));
	}

	.side-rail a {
		position: relative;
		display: grid;
		gap: 8px;
		width: fit-content;
		font-size: 0.98rem;
		letter-spacing: 0.14em;
		line-height: 1;
	}

	.side-rail span {
		color: inherit;
		font-size: 0.8rem;
		letter-spacing: 0.16em;
	}

	.side-rail .is-active {
		color: var(--paper);
	}

	.side-rail .is-active span {
		color: var(--cyan);
	}

	.side-rail .is-active::after {
		position: absolute;
		top: 24px;
		left: calc(100% + 18px);
		width: 32px;
		height: 2px;
		background: var(--cyan);
		content: "";
	}

	.hero-copy {
		position: relative;
		z-index: 4;
		padding-bottom: min(7vh, 58px);
		transform: translateY(clamp(-150px, -11svh, -96px));
	}

	.role-line {
		display: flex;
		align-items: center;
		gap: 22px;
		margin: 0 0 48px;
		color: var(--coral);
		font-family: var(--font-mono);
		font-size: 0.78rem;
		font-weight: 780;
		letter-spacing: 0.1em;
		line-height: 1;
		text-transform: uppercase;
	}

	.role-line span {
		width: 31px;
		height: 1px;
		background: var(--coral);
	}

	.hero h1 {
		max-width: 14.8ch;
		margin: 0;
		color: var(--paper);
		font-family: var(--font-mono);
		font-size: clamp(3rem, 3.45vw, 3.55rem);
		font-weight: 500;
		line-height: 1.18;
		letter-spacing: 0;
	}

	.hero h1 em {
		position: relative;
		color: var(--cyan);
		font-style: normal;
	}

	.hero h1 em::after {
		position: absolute;
		right: -0.08em;
		bottom: -0.07em;
		left: -0.05em;
		height: 0.08em;
		background: var(--cyan);
		transform: rotate(-4deg);
		content: "";
	}

	.hero-intro {
		max-width: 520px;
		margin: 34px 0 0;
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: clamp(0.98rem, 1.15vw, 1.13rem);
		line-height: 1.68;
	}

	.action-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 42px;
		margin-top: 48px;
	}

	.primary-action,
	.text-action,
	.all-projects,
	.contact-email,
	.contact-form button {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		color: var(--paper);
		font-family: var(--font-mono);
		font-size: 0.78rem;
		font-weight: 760;
		letter-spacing: 0.12em;
